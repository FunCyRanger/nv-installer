#!/bin/bash
#
# nv-install - Simple wrapper for nvidia-inst
#
# Usage:
#   nv-install --dry-run          # Simulate installation
#   nv-install --check            # Check compatibility
#   nv-install                    # Interactive install
#   nv-install --gui              # GUI mode
#   sudo nv-install              # Actual installation
#
# Options:
#   --dry-run, --simulate        Show what would be installed
#   --check                      Check compatibility only
#   --gui                        Launch GUI (Tkinter or Zenity)
#   --gui-type {tkinter,zenity} Force specific GUI
#   --driver-version VERSION     Install specific driver version
#   --no-cuda                    Install driver without CUDA
#   --yes, -y                    Skip confirmation prompts
#   --debug                      Enable debug logging
#   --version                    Show version
#   --help                       Show this help message
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check for python3
if ! command -v python3 &>/dev/null; then
    echo "Error: python3 not found. Please install Python 3.10 or newer." >&2
    exit 1
fi

# Check if module directory exists
if [[ ! -d "$SCRIPT_DIR/src/nvidia_inst" ]]; then
    echo "Error: nvidia_inst module not found at $SCRIPT_DIR/src/nvidia_inst" >&2
    echo "Make sure you are running this script from the project root." >&2
    exit 1
fi

export PYTHONPATH="$SCRIPT_DIR/src"

# Quick import test to catch missing dependencies
if ! python3 -c "import nvidia_inst" 2>/dev/null; then
    echo "Warning: nvidia_inst module cannot be imported." >&2
    echo "If you haven't installed dependencies, run:" >&2
    echo "  pip install -r requirements.txt" >&2
    echo "Continuing anyway..." >&2
fi

exec python3 -m nvidia_inst.cli "$@"
